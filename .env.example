# ====================================================================
# ENVIRONMENT CONFIGURATION (.env file)
# ====================================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to version control
# Add .env to .gitignore
# ====================================================================

# ==================== FLASK CONFIGURATION ==========================
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-here-change-this-in-production

# ==================== DATABASE CONFIGURATION =======================
DATABASE_URL=database.db
DATABASE_TYPE=sqlite

# ==================== SMS CONFIGURATION ============================
# Fast2SMS API Configuration
FAST2SMS_API_KEY=iQI5dDcMuwde5zmP3TOlmEHf5yLCcxsymQyh6zkCsVHssFziIcTZOIdehWUI
FAST2SMS_ENABLED=true
FAST2SMS_ROUTE=v3

# ==================== AI CHATBOT CONFIGURATION =====================
GOOGLE_API_KEY=your-google-api-key-here
AI_CHATBOT_ENABLED=true

# ==================== LOGGING CONFIGURATION ========================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==================== EMAIL CONFIGURATION (OPTIONAL) ================
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_SENDER_NAME=WorkHub AI
EMAIL_NOTIFICATIONS_ENABLED=false

# ==================== SECURITY CONFIGURATION =======================
# CORS Settings
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Session Configuration
SESSION_TIMEOUT=3600
SECURE_COOKIES=true
HTTP_ONLY_COOKIES=true

# ==================== FACE RECOGNITION CONFIGURATION ===============
# DeepFace Settings
FACE_DETECTION_THRESHOLD=0.6
FACE_RECOGNITION_THRESHOLD=0.4
MIN_DETECTION_STABILITY_FRAMES=5
FRAME_SKIP_INTERVAL=5

# ==================== DEPLOYMENT CONFIGURATION ====================
APP_HOST=0.0.0.0
APP_PORT=5000
APP_WORKERS=4
APP_TIMEOUT=120

# ==================== FILE UPLOAD CONFIGURATION ====================
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,png,gif
UPLOAD_FOLDER=static/uploads

# ====================================================================
# NOTES:
# 1. For production, use a strong SECRET_KEY (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# 2. For Gmail, enable 2FA and generate an app-specific password
# 3. For SMS notifications, get API key from https://www.fast2sms.com
# 4. For Google AI, get API key from https://console.cloud.google.com
# ====================================================================
